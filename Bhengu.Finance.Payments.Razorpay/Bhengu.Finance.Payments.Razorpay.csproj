<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <Version>2.1.0</Version>
    <PackageId>Bhengu.Finance.Payments.Razorpay</PackageId>
    <Authors>T.M. Bengu</Authors>
    <Company>Bhengu B.V.</Company>
    <Description>Razorpay (India) payment gateway for the Bhengu.Finance.Payments family. Cards, UPI, Netbanking, Wallets, EMI and RazorpayX payouts via the Razorpay REST API.</Description>
