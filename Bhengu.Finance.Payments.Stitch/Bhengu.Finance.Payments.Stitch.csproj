<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <Version>2.1.0</Version>
    <PackageId>Bhengu.Finance.Payments.Stitch</PackageId>
    <Authors>T.M. Bengu</Authors>
    <Company>Bhengu B.V.</Company>
    <Description>Stitch open-banking provider for the Bhengu.Finance.Payments family. South African pay-by-bank, InstantEFT, and LinkPay covering FNB, ABSA, Standard Bank, Nedbank, Capitec, Investec, and Discovery via Stitch GraphQL.</Description>
    <PackageTags>Payments;Payment Gateway;Bhengu;Bengu;Stitch;OpenBanking;SouthAfrica;ZAR;PayByBank;InstantEFT;LinkPay;GraphQL;Payout</PackageTags>
    <RepositoryUrl>https://github.com/bhengubv/Bhengu.Finance.Payments</RepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="9.0.6" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Bhengu.Finance.Payments.Core\Bhengu.Finance.Payments.Core.csproj" />
  </ItemGroup>
</Project>
