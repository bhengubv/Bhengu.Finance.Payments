<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <Version>2.1.0</Version>
    <PackageId>Bhengu.Finance.Payments.WeChatPay</PackageId>
    <Authors>T.M. Bengu</Authors>
    <Company>Bhengu B.V.</Company>
    <Description>WeChat Pay (Tencent) payment provider for the Bhengu.Finance.Payments family. WeChat Pay v3 API — Native/QR, JSAPI, App charges, refunds and partner batch transfers (payouts). RSA-SHA256 signed requests, AEAD-AES-256-GCM webhook decryption, signature verification.</Description>
    <PackageTags>Payments;Payment Gateway;Bhengu;Bengu;WeChatPay;WeChat;Tencent;China;Alipay;UnionPay;BricsPay;BRICS</PackageTags>
    <RepositoryUrl>https://github.com/bhengubv/Bhengu.Finance.Payments</RepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.9" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Bhengu.Finance.Payments.Core\Bhengu.Finance.Payments.Core.csproj" />
  </ItemGroup>
</Project>
